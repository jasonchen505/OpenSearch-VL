%% ============================================================
%% Annotator command for review comments
%% ============================================================
%% Usage:
%%   \annotator{alice}{red}
%%   \alice{This needs revision.}       → [ALICE: This needs revision.] in red
%%   \alicedel{Remove this sentence.}   → [ALICE: R̶e̶m̶o̶v̶e̶ ̶t̶h̶i̶s̶.̶] in red (strikethrough)
%%
%% With \usepackage[final]{scai}, all annotations are silently removed.
\RequirePackage[normalem]{ulem}
\newcommand{\annotator}[2]{%
  \if@scai@final
    \expandafter\DeclareDocumentCommand\csname#1\endcsname{o m}{}%
  \else
    \expandafter\DeclareDocumentCommand\csname#1\endcsname{o m}{%
      {\color{#2} [\textbf{\MakeUppercase #1}:\space
        \IfValueTF{##1}{\sout{##2}}{\ignorespaces##2\unskip}%
      ]}%
    }%
  \fi
}

%% ============================================================
%% Appendix support
%% ============================================================
%% Reset counters for supplementary numbering (S1, S2, ...)
\newcommand{\appendixprefix}{%
\setcounter{figure}{0}%
\renewcommand{\thefigure}{S\arabic{figure}}%
\setcounter{table}{0}%
\renewcommand{\thetable}{S\arabic{table}}%
\setcounter{lstlisting}{0}%
\renewcommand{\thelstlisting}{S\arabic{lstlisting}}%
\setcounter{algorithm}{0}%
\renewcommand{\thealgorithm}{S\arabic{algorithm}}%
\setcounter{equation}{0}%
\renewcommand{\theequation}{S\arabic{equation}}%
}

%% \makeappendixtitle[title] — starts appendix with title + TOC
%% Default title is "Supplementary Materials"
\newcommand{\makeappendixtitle}[1][Supplementary Materials]{%
  \newpage
  \appendix
  \appendixprefix
  {\centering\Large\sffamily\bfseries #1\par}%
  \vspace{14pt}%
  \startcontents[appendix]%
  \printcontents[appendix]{}{1}{\setcounter{tocdepth}{2}}%
}

