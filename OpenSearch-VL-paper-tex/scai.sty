\newcommand{\titlefont}{\huge\sffamily\bfseries}
\newcommand{\authorfont}{\normalsize\sffamily}
\newcommand{\keywordsfont}{\normalsize}
\newcommand{\absfont}{\normalsize}
\newcommand{\footerfont}{\normalfont\normalsize}

%% ============================================================
%% Header / Footer (first page and subsequent)
%% ============================================================
\pagestyle{fancy}
\renewcommand{\headrulewidth}{1pt}
\renewcommand{\footrulewidth}{0pt}
\let\@scai@DefaultHeadRule\headrule
\renewcommand{\headrule}{\color{gray}\@scai@DefaultHeadRule}

%% Default page style — no header, centered page number
\fancyhf{}
\renewcommand{\headrulewidth}{0pt}
\fancyfoot[C]{\footerfont\thepage}

%% Override plain style too (used by \maketitle, \chapter, etc.)
\fancypagestyle{plain}{%
  \fancyhf{}%
  \renewcommand{\headrulewidth}{0pt}%
  \fancyfoot[C]{\footerfont\thepage}%
}

%% First-page style — logos + header rule + contrib notes in footer
\fancypagestyle{scaifirstpage}{%
  \fancyhf{}%
  \fancyhead[L]{\includegraphics[height=35pt]{logo/logo.pdf}}%
  \fancyhead[R]{\includegraphics[height=30pt]{logo/hunyuan-logo.png}}%
  \fancyfoot[L]{\footnotesize\itshape\@scai@rendercontribfooter}%
  \fancyfoot[R]{\footerfont\thepage}%
  \renewcommand{\headrulewidth}{1pt}%
  \renewcommand{\headrule}{\color{gray}\@scai@DefaultHeadRule}%
  \renewcommand{\footrulewidth}{0.4pt}%
}

%% ============================================================
%% Abstract environment (capture content)
%% ============================================================
\def\xabstract{abstract}
\long\def\abstract#1\end#2{%
  \def\@scai@temptwo{#2}%
  \ifx\@scai@temptwo\xabstract
    \long\gdef\@scai@abstract{\ignorespaces#1}%
    \def\@scai@go{\end{abstract}}%
  \else
    #1\end{#2}%
    \gdef\@scai@abstract{BADLY FORMED ABSTRACT}%
    \let\@scai@go\relax
  \fi
  \@scai@go
}

%% ============================================================
%% Render abstract block (light blue tcolorbox)
%% ============================================================
\newcommand{\@scai@renderabstract}{%
  \begin{tcolorbox}[
    colframe=uclalightblue,
    colback=uclalightblue,
    boxrule=0pt,
    arc=2mm,
    enhanced,
    top=12pt,
    bottom=12pt,
    left=15pt,
    right=15pt,
    width=\textwidth,
  ]
  {\absfont \@scai@abstract}
  %% Correspondence + generic metadata fields inside abstract box
  \ifnum\numexpr
    \ifnum\value{scai@numcorr}>0 1\else 0\fi
    +\value{scai@nummeta}>0
    \par\vspace{8pt}
    \begingroup
    \fontsize{10}{12}\selectfont
    \setlength{\parskip}{1pt}%
    %% Correspondence (always first if present)
    \if@scai@hascorrespondence
      {\sffamily\textbf{Correspondence:}} \@scai@corrlist\par
    \fi
    %% Generic metadata entries
    \ifnum\value{scai@nummeta}>0
      \newcounter{scai@metaiter}%
      \setcounter{scai@metaiter}{0}%
      \loop\ifnum\value{scai@metaiter}<\value{scai@nummeta}%
        \stepcounter{scai@metaiter}%
        {\sffamily\textbf{\csname @scai@meta@\the\value{scai@metaiter}@label\endcsname:}}
        \csname @scai@meta@\the\value{scai@metaiter}@value\endcsname\par
      \repeat
    \fi
    \endgroup
  \fi
  \end{tcolorbox}
}

%% ============================================================
%% \maketitle — left-aligned title block
%% ============================================================
\renewcommand{\maketitle}{%
  \bgroup
  \setlength{\parindent}{0pt}%
  \setlength{\parskip}{0pt}%
  \vspace*{3pt}%
  %% Title (left-aligned, Arial/Helvetica, bold, black)
  {\raggedright\titlefont\@title\par}%
  \vspace{14pt}%
  %% Author list (Arial/Helvetica)
  {\raggedright\authorfont\@scai@authorlist\par}%
  \vspace{8pt}%
  %% Affiliations
  {\raggedright\@scai@renderaffils}%
  %% Keywords
  \if@scai@haskeywords
    \vspace{6pt}%
    {\raggedright\keywordsfont{\sffamily\textbf{Keywords:}} \@scai@keywords\par}%
  \fi
  \vspace{10pt}%
  %% Abstract (includes metadata fields inside the box)
  \@scai@renderabstract
  \egroup
  \thispagestyle{scaifirstpage}%
}

%% ============================================================
%% Section headings — UCLA blue, Arial/Helvetica, bold
%% ============================================================
\setcounter{secnumdepth}{3}

%% Section headings via \@startsection (like NeurIPS/ICML)
%% Positive afterskip ensures \nopagebreak is inserted after heading
\makeatletter
\renewcommand{\section}{%
  \@startsection{section}{1}{\z@}%
    {-3.5ex \@plus -1.0ex \@minus -0.2ex}%
    { 2.3ex \@plus  0.2ex}%
    {\Large\sffamily\bfseries\color{uclablue}\raggedright}%
}
\renewcommand{\subsection}{%
  \@startsection{subsection}{2}{\z@}%
    {-3.25ex \@plus -1.0ex \@minus -0.2ex}%
    { 1.5ex \@plus  0.2ex}%
    {\large\sffamily\bfseries\color{uclablue}\raggedright}%
}
\renewcommand{\subsubsection}{%
  \@startsection{subsubsection}{3}{\z@}%
    {-3.25ex \@plus -1.0ex \@minus -0.2ex}%
    { 1.5ex \@plus  0.2ex}%
    {\normalsize\sffamily\bfseries\color{uclablue}\raggedright}%
}
\makeatother

%% Prevent widows/orphans and orphaned headings
\clubpenalty=10000
\widowpenalty=10000
\raggedbottom

%% Ensure enough space for heading + content before page break
\RequirePackage{needspace}
\makeatletter
\pretocmd{\@startsection}{\needspace{2\baselineskip}}{}{}
\makeatother

