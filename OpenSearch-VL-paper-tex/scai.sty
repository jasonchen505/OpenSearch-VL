%% ============================================================
%% Internal storage
%% ============================================================
\newcommand{\@scai@keywords}{}
\newcommand{\@scai@abstract}{}

\newif\if@scai@haskeywords   \@scai@haskeywordsfalse
\newif\if@scai@hascorrespondence \@scai@hascorrespondencefalse

%% Generic metadata list
\newcounter{scai@nummeta}
\setcounter{scai@nummeta}{0}

%% ============================================================
%% User-facing commands: metadata
%% ============================================================
\newcommand{\scaikeywords}[1]{%
  \renewcommand{\@scai@keywords}{#1}%
  \@scai@haskeywordstrue
}

%% Correspondence: \correspondence{Name}{email} (supports multiple calls)
\newcounter{scai@numcorr}
\setcounter{scai@numcorr}{0}
\newcommand{\@scai@corrlist}{}
\newcommand{\correspondence}[2]{%
  \@scai@hascorrespondencetrue
  \stepcounter{scai@numcorr}%
  \ifnum\value{scai@numcorr}=1
    \gdef\@scai@corrlist{#1 (\href{mailto:#2}{#2})}%
  \else
    \g@addto@macro\@scai@corrlist{, #1 (\href{mailto:#2}{#2})}%
  \fi
}

%% Generic metadata: \metadata[Label]{value}
\newcommand{\metadata}[2][]{%
  \stepcounter{scai@nummeta}%
  \expandafter\gdef\csname @scai@meta@\the\value{scai@nummeta}@label\endcsname{#1}%
  \expandafter\gdef\csname @scai@meta@\the\value{scai@nummeta}@value\endcsname{#2}%
}

%% ============================================================
%% Author / affiliation system
%% ============================================================
%% Usage:
%%   \scaiauthor{1}{Yanqiao Zhu}
%%   \scaiauthor{1,equal}{Yanqiao Zhu}
%%   \scaiauthor{1,2,equal,corr}{Yanqiao Zhu}
%%
%%   \affiliation{1}{University of California, Los Angeles}
%%   \contribnote{equal}{*}{Equal contribution as first authors.}
%%   \contribnote{corr}{\ddag}{Corresponding author.}
%%   \contribnote{lead}{\P}{Project lead.}
%%
\newcounter{scai@numauthors}
\setcounter{scai@numauthors}{0}
\newcounter{scai@numaffils}
\setcounter{scai@numaffils}{0}
\newcounter{scai@numnotes}
\setcounter{scai@numnotes}{0}

\newcommand{\@scai@authorlist}{}
\newcommand{\@scai@affillist}{}

%% Define a contribution note:
%%   \contribnote{key}{symbol}{description}  — explicit symbol
%%   \contribnote{key}{description}           — auto-assign symbol (*, †, ‡, §, ...)
%% Must be defined BEFORE \scaiauthor calls that reference the key.
\NewDocumentCommand{\contribnote}{m m g}{%
  \stepcounter{scai@numnotes}%
  \IfNoValueTF{#3}{%
    %% 2-arg form: store counter value, render \fnsymbol at use time
    \begingroup
    \edef\@scai@tmpdef{%
      \noexpand\gdef\expandafter\noexpand\csname @scai@notesym@#1\endcsname{%
        \noexpand\@fnsymbol{\the\value{scai@numnotes}}}%
    }%
    \@scai@tmpdef
    \endgroup
    \expandafter\gdef\csname @scai@notetxt@#1\endcsname{#2}%
  }{%
    %% 3-arg form: explicit symbol
    \expandafter\gdef\csname @scai@notesym@#1\endcsname{#2}%
    \expandafter\gdef\csname @scai@notetxt@#1\endcsname{#3}%
  }%
  %% Store ordering
  \expandafter\gdef\csname @scai@noteord@\the\value{scai@numnotes}\endcsname{#1}%
}

%% Add an affiliation: \affiliation{key}{text}
\newcommand{\affiliation}[2]{%
  \expandafter\gdef\csname @scai@affil@#1\endcsname{#2}%
  \stepcounter{scai@numaffils}%
  \ifnum\value{scai@numaffils}=1
    \gdef\@scai@affillist{#1}%
  \else
    \g@addto@macro\@scai@affillist{,#1}%
  \fi
}

%% Resolve a single tag: if it's a contribnote key, use its symbol; otherwise literal
\newcommand{\@scai@resolvetag}[1]{%
  \@ifundefined{@scai@notesym@#1}{#1}{\csname @scai@notesym@#1\endcsname}%
}

%% Add an author: \scaiauthor{tags}{Name}
\newcommand{\scaiauthor}[2]{%
  \stepcounter{scai@numauthors}%
  \ifnum\value{scai@numauthors}=1
    \gdef\@scai@authorlist{\mbox{#2\textsuperscript{\@scai@rendertags{#1}}}}%
  \else
    \g@addto@macro\@scai@authorlist{, \mbox{#2\textsuperscript{\@scai@rendertags{#1}}}}%
  \fi
}

%% Render tags: resolve each comma-separated item
\newcommand{\@scai@rendertags}[1]{%
  \def\@scai@first{1}%
  \@for\@scai@curtag:=#1\do{%
    \if\@scai@first 1\def\@scai@first{0}\else,\fi
    \@scai@resolvetag{\@scai@curtag}%
  }%
}

%% Render affiliation list (line break between affiliation 2 and 3)
\newcommand{\@scai@renderaffils}{%
  \begingroup
  \normalsize\itshape
  \def\@scai@affilfirst{1}%
  \@for\@scai@tmp:=\@scai@affillist\do{%
    \ifnum\@scai@tmp=3\relax \par\def\@scai@affilfirst{1}\fi
    \if\@scai@affilfirst 1\def\@scai@affilfirst{0}\else ,\space\fi
    \textsuperscript{\@scai@tmp}%
    \csname @scai@affil@\@scai@tmp\endcsname
  }%
  \par
  \endgroup
}

%% Render contribution notes (inline, for footer)
\newcommand{\@scai@rendercontribfooter}{%
  \ifnum\value{scai@numnotes}>0
    \begingroup
    \newcounter{scai@footiter}%
    \setcounter{scai@footiter}{0}%
    \def\@scai@footfirst{1}%
    \loop\ifnum\value{scai@footiter}<\value{scai@numnotes}%
      \stepcounter{scai@footiter}%
      \if\@scai@footfirst 1\def\@scai@footfirst{0}\else \quad\fi
      \edef\@scai@notekey{\csname @scai@noteord@\the\value{scai@footiter}\endcsname}%
      \textsuperscript{\csname @scai@notesym@\@scai@notekey\endcsname}%
      \csname @scai@notetxt@\@scai@notekey\endcsname
    \repeat
    \endgroup
  \fi
}

%% Render contribution notes (block, for title area)
\newcommand{\@scai@rendercontribnotes}{%
  \ifnum\value{scai@numnotes}>0
    \begingroup
    \vspace{4pt}%
    \normalsize\itshape
    \newcounter{scai@noteiter}%
    \setcounter{scai@noteiter}{0}%
    \def\@scai@notefirst{1}%
    \loop\ifnum\value{scai@noteiter}<\value{scai@numnotes}%
      \stepcounter{scai@noteiter}%
      \if\@scai@notefirst 1\def\@scai@notefirst{0}\else \space\fi
      \edef\@scai@notekey{\csname @scai@noteord@\the\value{scai@noteiter}\endcsname}%
      \textsuperscript{\csname @scai@notesym@\@scai@notekey\endcsname}%
      \csname @scai@notetxt@\@scai@notekey\endcsname
    \repeat
    \par
    \endgroup
  \fi
}

